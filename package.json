{
  "name": "pulse",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "seed": "npm run seed --workspace server",
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev --workspace server\" \"npm run dev --workspace web\"",
    "build": "npm run build --workspace web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
